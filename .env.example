# Application Settings
APP_ENV=development
APP_URL=http://localhost
# 32-byte hexadecimal key for AES-256-GCM encryption (e.g. 64 hex characters)
APP_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
# 32-byte hexadecimal key for HMAC-SHA256 hashing (e.g. 64 hex characters)
APP_HMAC_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789

# Database Settings (follows cPanel prefix conventions if on cPanel hosting)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinicdb
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Default Account Seeds (If password is empty, a random 16-character password will be generated and logged to storage/seeded_credentials.txt)
DEFAULT_PATIENT_EMAIL=patient@clinic.com
DEFAULT_PATIENT_PASSWORD=
DEFAULT_DOCTOR_EMAIL=doctor@clinic.com
DEFAULT_DOCTOR_PASSWORD=
DEFAULT_RECEPTIONIST_EMAIL=receptionist@clinic.com
DEFAULT_RECEPTIONIST_PASSWORD=
DEFAULT_ADMIN_EMAIL=admin@clinic.com
DEFAULT_ADMIN_PASSWORD=
DEFAULT_APOTEKER_EMAIL=apoteker@clinic.com
DEFAULT_APOTEKER_PASSWORD=
