# Protect sensitive files
<FilesMatch "^\.(env|gitignore)|composer\.(json|lock)$">
    <IfModule authz_core_module>
        Require all denied
    </IfModule>
    <IfModule !authz_core_module>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent directory browsing
Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Block direct access to sensitive directories
    RewriteRule ^(src|database|storage|logs)/.*$ - [F,L]

    # Block direct access to PHP files inside sensitive dirs
    RewriteRule ^(src|database|storage|logs)/.*\.php$ - [F,L]

    # Redirect non-existent files/folders to index.php (Clean URLs)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

# PHP error settings for production safety
<IfModule mod_php.c>
    php_flag display_errors Off
    php_flag log_errors On
</IfModule>
